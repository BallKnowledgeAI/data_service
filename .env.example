# -----------------------------------------------------------------------
# Tactical Analysis Pipeline — environment template
# Copy this file to .env and fill in your values.
# .env is gitignored and must NEVER be committed.
# -----------------------------------------------------------------------

# --- Postgres ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tactical_analysis
POSTGRES_USER=tactical_user
POSTGRES_PASSWORD=changeme_dev_only

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
# Leave blank for no-auth (default for local Docker dev).
# Set a strong value for any non-localhost environment.
REDIS_PASSWORD=
